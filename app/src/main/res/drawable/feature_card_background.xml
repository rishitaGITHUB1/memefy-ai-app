<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Glow effect -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#3000d4ff" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Border -->
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#4000d4ff" />
            <solid android:color="#2d3142" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</layer-list>