<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Top Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_rocket" android:contentDescription="Logo"/>
        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="MEMEFY-AI"
            android:textColor="@color/accent_blue" android:textSize="18sp"
            android:textStyle="bold" android:layout_marginStart="8dp"/>
        <ImageView android:id="@+id/btn_menu"
            android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/ic_menu" android:contentDescription="Menu"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Welcome Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👋 " android:textSize="28sp"/>
                <LinearLayout
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tv_welcome"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Welcome back," android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/accent_blue"/>
                    <TextView
                        android:id="@+id/tv_username"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Meme Master!" android:textSize="26sp" android:textStyle="bold"
                        android:textColor="#4ECDC4"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ready to create some viral content today? Let's see what you've been up to! 📊"
                android:textSize="14sp" android:textColor="@color/text_secondary"
                android:lineSpacingExtra="4dp" android:layout_marginBottom="24dp"/>

            <!-- ── STAT CARDS (full width, one per row like screenshots) ── -->

            <!-- Memes Created -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_memes"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_pink" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎨" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_memes"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Memes Created" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total memes in your collection" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Total Views -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_views"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_blue" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👁" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_views"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Total Views" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="People who viewed your memes" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Shares -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_shares"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_green" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📤" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_shares"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Shares" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Times your memes were shared" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Trending Score -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_trending"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_orange" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🔥" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_trending"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Trending Score" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Your viral potential rating" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Avg Toxicity -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_toxicity"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_blue" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🛡" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_toxicity"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0%" android:textSize="32sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Avg Toxicity" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Average toxicity across your memes" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Sentiment Mix -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_stat_sentiment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_green" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💬" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:id="@+id/tv_stat_sentiment"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0/0/0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sentiment Mix" android:textSize="15sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Safe / Neutral / Risky memes" android:textSize="12sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── QUICK ACTIONS ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Quick Actions" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/accent_blue" android:layout_marginBottom="16dp"/>

            <!-- Create New Meme -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_create_meme"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_pink" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎨" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Create New Meme" android:textSize="17sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Start creating amazing content" android:textSize="13sp"
                            android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="→" android:textSize="24sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Browse Gallery -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_browse_gallery"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_blue" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🖼" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Browse Gallery" android:textSize="17sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Explore viral memes" android:textSize="13sp"
                            android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="→" android:textSize="24sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- View Profile -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_view_profile"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:clickable="true" android:focusable="true">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp" android:gravity="center_vertical">
                    <View android:layout_width="56dp" android:layout_height="56dp"
                        android:background="@drawable/stat_icon_bg_green" android:layout_marginEnd="16dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="👤" android:textSize="28sp" android:layout_marginStart="-72dp"
                        android:layout_marginEnd="32dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="View Profile" android:textSize="17sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="See your meme collection" android:textSize="13sp"
                            android:textColor="@color/text_secondary" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="→" android:textSize="24sp" android:textColor="@color/text_secondary"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── RECENT ACTIVITY ── -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Recent Activity" android:textSize="22sp" android:textStyle="bold"
                android:textColor="@color/accent_blue" android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/recent_activity_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp"/>

            <!-- ── MEME TIP OF THE DAY ── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1e2235" app:cardCornerRadius="16dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="28dp" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💡" android:textSize="48sp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Meme Tip " android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="of the Day" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="#4ECDC4"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:id="@+id/tv_tip"
                        android:text="The best memes capture universal experiences in unexpected ways. Think about what made you laugh today!"
                        android:textSize="15sp" android:textColor="@color/text_secondary"
                        android:gravity="center" android:layout_marginTop="12dp"
                        android:lineSpacingExtra="4dp"/>
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginTop="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="#Relatable" android:textSize="13sp" android:textColor="#FFFFFF"
                            android:background="@drawable/tag_pink_bg"
                            android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="#Trending" android:textSize="13sp" android:textColor="#FFFFFF"
                            android:background="@drawable/tag_blue_bg"
                            android:paddingHorizontal="16dp" android:paddingVertical="8dp"/>
                    </LinearLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="#Viral" android:textSize="13sp" android:textColor="#FFFFFF"
                        android:background="@drawable/tag_yellow_bg"
                        android:paddingHorizontal="16dp" android:paddingVertical="8dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav (Stats active, 5 items when logged in) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@drawable/bottom_nav_bg"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:weightSum="5">

        <LinearLayout android:id="@+id/nav_home_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" android:contentDescription="Home"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_create_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_generator" android:contentDescription="Create"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_gallery_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_gallery" android:contentDescription="Gallery"/>
        </LinearLayout>

        <!-- Stats active -->
        <LinearLayout android:id="@+id/nav_stats_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center"
            android:background="@drawable/bottom_nav_active"
            android:paddingHorizontal="8dp"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_dashboard" android:contentDescription="Stats"
                android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Stats" android:textColor="#FFFFFF" android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_profile_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_profile" android:contentDescription="Profile"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>