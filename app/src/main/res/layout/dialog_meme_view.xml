<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/pink_glow_border"
    android:padding="0dp">

    <!-- Meme Image with close button overlay -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="380dp">

        <ImageView
            android:id="@+id/iv_fullscreen_meme"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Meme"/>

        <!-- Close button -->
        <TextView
            android:id="@+id/btn_close_view"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="#AA000000"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:clickable="true"
            android:focusable="true"/>
    </FrameLayout>

    <!-- Info section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0f1221"
        android:padding="16dp">

        <TextView
            android:id="@+id/tv_view_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Meme Title"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">
            <TextView
                android:id="@+id/tv_view_author"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@Anonymous" android:textSize="13sp"
                android:textColor="@color/accent_blue"/>
            <TextView
                android:id="@+id/tv_view_date"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="2024-01-15" android:textSize="13sp"
                android:textColor="@color/text_secondary"/>
        </LinearLayout>

        <!-- Tags -->
        <LinearLayout
            android:id="@+id/view_tags_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp"/>

        <!-- Stats + action buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_view_fire"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔥 2.3k" android:textSize="14sp" android:textColor="@color/text_primary"
                android:layout_marginEnd="16dp"/>

            <TextView
                android:id="@+id/tv_view_views"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="👁 15.6k" android:textSize="14sp" android:textColor="@color/text_primary"/>

            <!-- Like -->
            <TextView
                android:id="@+id/btn_view_like"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="🤍" android:textSize="20sp" android:gravity="center"
                android:background="@drawable/card_normal_border"
                android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>

            <!-- Share -->
            <TextView
                android:id="@+id/btn_view_share"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="📤" android:textSize="18sp" android:gravity="center"
                android:background="@drawable/card_normal_border"
                android:layout_marginEnd="8dp"
                android:clickable="true" android:focusable="true"/>

            <!-- Download -->
            <TextView
                android:id="@+id/btn_view_download"
                android:layout_width="44dp" android:layout_height="44dp"
                android:text="⬇" android:textSize="18sp" android:gravity="center"
                android:background="@drawable/card_normal_border"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>