<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Top Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_rocket" android:contentDescription="Logo"/>

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MEMEFY-AI"
            android:textColor="#C850C0"
            android:textSize="18sp" android:textStyle="bold"
            android:layout_marginStart="8dp"/>

        <ImageView android:id="@+id/btn_menu"
            android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/ic_menu" android:contentDescription="Menu"
            android:clickable="true" android:focusable="true"/>
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Hero Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingHorizontal="24dp"
                android:paddingTop="24dp"
                android:paddingBottom="16dp">

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Viral Meme " android:textSize="36sp" android:textStyle="bold"
                        android:textColor="@color/accent_blue"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Gallery" android:textSize="36sp" android:textStyle="bold"
                        android:textColor="#4ECDC4"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="The freshest memes straight from the internet's finest creators 🔥"
                    android:textSize="14sp" android:textColor="@color/text_secondary"
                    android:gravity="center" android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"/>
            </LinearLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/card_normal_border"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Search memes..."
                    android:background="@null"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"/>

                <ImageView
                    android:id="@+id/btn_search"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:contentDescription="Search"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

            <!-- Hashtag Filter Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:id="@+id/filter_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/chip_all"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="🌐 All" android:textSize="13sp" android:textColor="#FFFFFF"
                        android:background="@drawable/gradient_button"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_relatable"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#relatable" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_work"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#work" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_school"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#school" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_money"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#money" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_coding"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#coding" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:layout_marginEnd="8dp" android:clickable="true" android:focusable="true"/>

                    <TextView android:id="@+id/chip_adulting"
                        android:layout_width="wrap_content" android:layout_height="40dp"
                        android:text="#adulting" android:textSize="13sp" android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="16dp" android:gravity="center"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Meme Feed (populated programmatically) -->
            <LinearLayout
                android:id="@+id/meme_feed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"/>

            <!-- Footer -->
            <TextView
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:text="© 2025 MEMEFY AI"
                android:textSize="12sp" android:textColor="@color/text_secondary"
                android:padding="20dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav (Gallery active) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@drawable/bottom_nav_bg"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:weightSum="5">

        <LinearLayout android:id="@+id/nav_home_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" android:contentDescription="Home"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_create_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_generator" android:contentDescription="Create"/>
        </LinearLayout>

        <!-- Gallery active -->
        <LinearLayout android:id="@+id/nav_gallery_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center"
            android:background="@drawable/bottom_nav_active"
            android:paddingHorizontal="10dp"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_gallery" android:contentDescription="Gallery"
                android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gallery" android:textColor="#FFFFFF" android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_stats_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_dashboard" android:contentDescription="Stats"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_profile_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_profile" android:contentDescription="Profile"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>