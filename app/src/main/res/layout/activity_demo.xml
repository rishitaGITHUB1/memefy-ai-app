<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Navigation Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="@color/primary_dark">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_rocket"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MEMEFY-AI"
                android:textColor="@color/accent_blue"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginStart="8dp" />

            <ImageView
                android:id="@+id/btn_menu"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_menu"
                android:contentDescription="Menu"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Scrollable content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MEME " android:textSize="36sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎨 " android:textSize="32sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="FACTORY" android:textSize="36sp" android:textStyle="bold"
                            android:textColor="@color/accent_purple" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Create viral content in seconds • No cap 📈"
                        android:textSize="14sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp" android:gravity="center" />
                </LinearLayout>

                <!-- Mode Tabs -->
                <HorizontalScrollView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:scrollbars="none" android:paddingHorizontal="16dp"
                    android:layout_marginBottom="12dp">
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:id="@+id/tab_templates"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Templates 🖼" android:textSize="13sp" android:textColor="#FFFFFF"
                            android:background="@drawable/gradient_button" android:paddingHorizontal="16dp"
                            android:gravity="center" android:layout_marginEnd="8dp"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tab_ai"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="AI Generator 🤖" android:textSize="13sp" android:textColor="@color/text_primary"
                            android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                            android:gravity="center" android:layout_marginEnd="8dp"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tab_customize"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Customize ✏" android:textSize="13sp" android:textColor="@color/text_primary"
                            android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                            android:gravity="center" android:layout_marginEnd="8dp"
                            android:clickable="true" android:focusable="true" />
                        <TextView android:id="@+id/tab_effects"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Effects ✨" android:textSize="13sp" android:textColor="@color/text_primary"
                            android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                            android:gravity="center" android:clickable="true" android:focusable="true" />
                    </LinearLayout>
                </HorizontalScrollView>

                <!-- ═══════════════════════════════════════
                     SECTION: TEMPLATES
                     ═══════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/section_templates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <HorizontalScrollView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:scrollbars="none" android:paddingHorizontal="16dp"
                        android:layout_marginBottom="16dp">
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:id="@+id/filter_all"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="All (100)" android:textSize="13sp" android:textColor="#FFFFFF"
                                android:background="@drawable/gradient_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:layout_marginEnd="8dp"
                                android:clickable="true" android:focusable="true"/>
                            <TextView android:id="@+id/filter_popular"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Popular (93)" android:textSize="13sp" android:textColor="@color/text_primary"
                                android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:layout_marginEnd="8dp"
                                android:clickable="true" android:focusable="true"/>
                            <TextView android:id="@+id/filter_trending"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Trending (1)" android:textSize="13sp" android:textColor="@color/text_primary"
                                android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:layout_marginEnd="8dp"
                                android:clickable="true" android:focusable="true"/>
                            <TextView android:id="@+id/filter_classic"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Classic (4)" android:textSize="13sp" android:textColor="@color/text_primary"
                                android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:layout_marginEnd="8dp"
                                android:clickable="true" android:focusable="true"/>
                            <TextView android:id="@+id/filter_gaming"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Gaming" android:textSize="13sp" android:textColor="@color/text_primary"
                                android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:layout_marginEnd="8dp"
                                android:clickable="true" android:focusable="true"/>
                            <TextView android:id="@+id/filter_reaction"
                                android:layout_width="wrap_content" android:layout_height="36dp"
                                android:text="Reaction (2)" android:textSize="13sp" android:textColor="@color/text_primary"
                                android:background="@drawable/outline_button" android:paddingHorizontal="16dp"
                                android:gravity="center" android:clickable="true" android:focusable="true"/>
                        </LinearLayout>
                    </HorizontalScrollView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/memes_grid"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="8dp" android:nestedScrollingEnabled="false" android:clipToPadding="false" />

                    <ProgressBar android:id="@+id/progress_bar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent" android:layout_height="8dp"
                        android:layout_marginHorizontal="20dp" android:layout_marginTop="20dp"
                        android:progress="20" android:max="100"
                        android:progressTint="@color/accent_blue" android:progressBackgroundTint="#3a3f55" />

                    <TextView android:id="@+id/tv_showing_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_gravity="center" android:layout_marginTop="12dp"
                        android:gravity="center" android:layout_marginHorizontal="20dp"
                        android:textSize="15sp" android:textColor="@color/text_secondary"
                        android:text="Showing 5 of 100 templates" />

                    <Button android:id="@+id/btn_load_more"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:layout_margin="20dp" android:text="🚀  Load 20 More Templates"
                        android:textColor="#FFFFFF" android:background="@drawable/gradient_button"
                        android:textAllCaps="false" android:textSize="16sp" android:textStyle="bold" />

                </LinearLayout>

                <!-- ═══════════════════════════════════════
                     SECTION: CUSTOMIZE
                     ═══════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/section_customize"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <!-- Text Content Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp" app:cardBackgroundColor="#1e2235"
                        app:cardCornerRadius="16dp" app:cardElevation="6dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="✏ Text Content" android:textSize="16sp" android:textStyle="bold"
                                android:textColor="@color/accent_purple" android:layout_marginBottom="12dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Text 1 (Top)" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="4dp"/>
                            <EditText android:id="@+id/et_top_text"
                                android:layout_width="match_parent" android:layout_height="80dp"
                                android:hint="Enter text 1 (top)..." android:background="@drawable/card_border"
                                android:padding="12dp" android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_secondary" android:gravity="top"
                                android:inputType="textMultiLine" android:layout_marginBottom="12dp"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Text 2 (Bottom)" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="4dp"/>
                            <EditText android:id="@+id/et_bottom_text"
                                android:layout_width="match_parent" android:layout_height="80dp"
                                android:hint="Enter text 2 (bottom)..." android:background="@drawable/card_border"
                                android:padding="12dp" android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_secondary" android:gravity="top"
                                android:inputType="textMultiLine"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Advanced Styling Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp" app:cardBackgroundColor="#1e2235"
                        app:cardCornerRadius="16dp" app:cardElevation="6dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="16dp">

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🎨 Advanced Styling" android:textSize="16sp" android:textStyle="bold"
                                android:textColor="@color/accent_blue" android:layout_marginBottom="16dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Font Family" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="4dp"/>
                            <Spinner android:id="@+id/spinner_font"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:background="@drawable/card_border" android:paddingHorizontal="12dp"
                                android:layout_marginBottom="12dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Font Size" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="4dp"/>
                            <Spinner android:id="@+id/spinner_size"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:background="@drawable/card_border" android:paddingHorizontal="12dp"
                                android:layout_marginBottom="12dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Text Alignment" android:textSize="13sp"
                                android:textColor="@color/text_secondary" android:layout_marginBottom="4dp"/>
                            <Spinner android:id="@+id/spinner_align"
                                android:layout_width="match_parent" android:layout_height="48dp"
                                android:background="@drawable/card_border" android:paddingHorizontal="12dp"
                                android:layout_marginBottom="16dp"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Top Text Position" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginBottom="8dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Horizontal"
                                    android:textSize="13sp" android:textColor="@color/text_secondary"/>
                                <TextView android:id="@+id/tv_h_percent"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="50%" android:textSize="13sp" android:textColor="@color/text_primary"
                                    android:background="@drawable/tag_blue_bg"
                                    android:paddingHorizontal="8dp" android:paddingVertical="2dp"/>
                            </LinearLayout>
                            <SeekBar android:id="@+id/seek_horizontal"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:layout_marginBottom="12dp"
                                android:progressTint="@color/accent_blue" android:thumbTint="@color/accent_blue"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">
                                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                    android:layout_weight="1" android:text="Vertical"
                                    android:textSize="13sp" android:textColor="@color/text_secondary"/>
                                <TextView android:id="@+id/tv_v_percent"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="10%" android:textSize="13sp" android:textColor="@color/text_primary"
                                    android:background="@drawable/tag_blue_bg"
                                    android:paddingHorizontal="8dp" android:paddingVertical="2dp"/>
                            </LinearLayout>
                            <SeekBar android:id="@+id/seek_vertical"
                                android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:layout_marginBottom="16dp"
                                android:progressTint="@color/accent_blue" android:thumbTint="@color/accent_blue"/>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Text Effect" android:textSize="13sp" android:textStyle="bold"
                                android:textColor="@color/text_primary" android:layout_marginBottom="10dp"/>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="8dp">
                                <Button android:id="@+id/btn_effect_shadow"
                                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                                    android:text="Shadow" android:textColor="#FFFFFF"
                                    android:background="@drawable/gradient_button" android:textAllCaps="false"
                                    android:layout_marginEnd="6dp"/>
                                <Button android:id="@+id/btn_effect_outline"
                                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                                    android:text="Outline" android:textColor="@color/text_primary"
                                    android:background="@drawable/outline_button" android:textAllCaps="false"/>
                            </LinearLayout>

                            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:weightSum="2">
                                <Button android:id="@+id/btn_effect_glow"
                                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                                    android:text="Glow" android:textColor="@color/text_primary"
                                    android:background="@drawable/outline_button" android:textAllCaps="false"
                                    android:layout_marginEnd="6dp"/>
                                <Button android:id="@+id/btn_effect_neon"
                                    android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                                    android:text="Neon" android:textColor="@color/text_primary"
                                    android:background="@drawable/outline_button" android:textAllCaps="false"/>
                            </LinearLayout>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Live Preview Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp" app:cardBackgroundColor="#1e2235"
                        app:cardCornerRadius="16dp" app:cardElevation="6dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="vertical" android:padding="16dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="👁 Live Preview" android:textSize="16sp" android:textStyle="bold"
                                android:textColor="#FF6B9D" android:layout_marginBottom="12dp"/>
                            <ImageView android:id="@+id/iv_live_preview"
                                android:layout_width="match_parent" android:layout_height="300dp"
                                android:scaleType="fitCenter" android:background="#0a0e1a"
                                android:contentDescription="Live meme preview"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- ✅ Generate Meme Button -->
                    <Button
                        android:id="@+id/btn_generate_meme"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="24dp"
                        android:text="🎨  Generate Meme"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/gradient_button"
                        android:textAllCaps="false"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- Footer -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:gravity="center" android:padding="24dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="© 2025 MEMEFY AI - Creating viral content with AI"
                        android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="center" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ✅ Bottom Navigation Bar -->
        <LinearLayout
            android:id="@+id/bottom_nav_demo"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="@drawable/bottom_nav_bg"
            android:paddingHorizontal="8dp"
            android:gravity="center_vertical"
            android:weightSum="4">

            <LinearLayout android:id="@+id/nav_home_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_home" android:contentDescription="Home"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_create_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="horizontal" android:gravity="center"
                android:background="@drawable/bottom_nav_active"
                android:paddingHorizontal="10dp"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_generator" android:contentDescription="Create"
                    android:layout_marginEnd="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Create" android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_gallery_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_gallery" android:contentDescription="Gallery"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_login_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_logout" android:contentDescription="Login"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_stats_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:visibility="gone"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_dashboard" android:contentDescription="Stats"/>
            </LinearLayout>

            <LinearLayout android:id="@+id/nav_profile_btn"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:orientation="vertical" android:gravity="center"
                android:visibility="gone"
                android:clickable="true" android:focusable="true">
                <ImageView android:layout_width="22dp" android:layout_height="22dp"
                    android:src="@drawable/ic_profile" android:contentDescription="Profile"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/secondary_dark"
        app:menu="@menu/drawer_menu"
        app:itemIconTint="@color/text_primary"
        app:itemTextColor="@color/text_primary"
        app:headerLayout="@layout/nav_header" />

</androidx.drawerlayout.widget.DrawerLayout>