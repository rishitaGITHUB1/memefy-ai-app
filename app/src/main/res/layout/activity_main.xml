<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_dark">

    <!-- ── Main content + bottom nav wrapper ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Scrollable page content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ── Top Nav ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_rocket"
                        android:contentDescription="Logo" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="MEMEFY-AI"
                        android:textColor="#C850C0"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginStart="8dp" />

                    <ImageView
                        android:id="@+id/btn_menu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_menu"
                        android:contentDescription="Menu"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- ── Hero Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingHorizontal="32dp"
                    android:paddingTop="48dp"
                    android:paddingBottom="32dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MEMEFY-AI"
                        android:textSize="44sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="The ultimate AI meme generator\nfor Gen-Z creators."
                        android:textSize="17sp"
                        android:textColor="@color/text_primary"
                        android:gravity="center"
                        android:layout_marginTop="20dp"
                        android:lineSpacingExtra="4dp" />

                    <!-- "No cap, just pure viral content!" in gradient-ish colors -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No cap, just "
                            android:textSize="16sp"
                            android:textColor="#C850C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="pure viral content!"
                            android:textSize="16sp"
                            android:textColor="@color/accent_blue" />
                    </LinearLayout>

                    <!-- Start Creating Button -->
                    <Button
                        android:id="@+id/btn_start_creating"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Start Creating Memes ✨"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/gradient_button"
                        android:textAllCaps="false"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:layout_marginTop="36dp" />

                    <!-- Too lazy / viral memes link -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Too lazy to sign up? We feel you 😴"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="28dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/btn_check_viral">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Check out viral memes"
                            android:textSize="15sp"
                            android:textColor="#F5A623"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" →"
                            android:textSize="15sp"
                            android:textColor="#F5A623"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <!-- ── Feature Cards ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="16dp"
                    android:paddingBottom="8dp">

                    <!-- Card 1: AI Meme Master -->
                    <LinearLayout
                        android:id="@+id/card_ai_master"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_normal_border"
                        android:padding="32dp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🤖" android:textSize="48sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="AI Meme Master" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" android:layout_marginTop="14dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Our AI knows every meme format from the classics to the latest viral hits"
                            android:textSize="15sp" android:textColor="@color/text_secondary"
                            android:gravity="center" android:layout_marginTop="10dp" android:lineSpacingExtra="4dp" />
                    </LinearLayout>

                    <!-- Card 2: Viral Potential -->
                    <LinearLayout
                        android:id="@+id/card_viral"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_normal_border"
                        android:padding="32dp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📈" android:textSize="48sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Viral Potential" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" android:layout_marginTop="14dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Generate memes that are guaranteed to get those likes, shares, and reactions"
                            android:textSize="15sp" android:textColor="@color/text_secondary"
                            android:gravity="center" android:layout_marginTop="10dp" android:lineSpacingExtra="4dp" />
                    </LinearLayout>

                    <!-- Card 3: Instant Creation -->
                    <LinearLayout
                        android:id="@+id/card_instant"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_normal_border"
                        android:padding="32dp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚡" android:textSize="48sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Instant Creation" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" android:layout_marginTop="14dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="From idea to meme in seconds. No cap. 💯"
                            android:textSize="15sp" android:textColor="@color/text_secondary"
                            android:gravity="center" android:layout_marginTop="10dp" android:lineSpacingExtra="4dp" />
                    </LinearLayout>

                    <!-- Card 4: Trend Tracker -->
                    <LinearLayout
                        android:id="@+id/card_trend"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_normal_border"
                        android:padding="32dp"
                        android:gravity="center"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🎯" android:textSize="48sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Trend Tracker" android:textSize="22sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" android:layout_marginTop="14dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Stay ahead with real-time meme trends from Reddit, Twitter, and TikTok"
                            android:textSize="15sp" android:textColor="@color/text_secondary"
                            android:gravity="center" android:layout_marginTop="10dp" android:lineSpacingExtra="4dp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- ── Fresh Memes Daily ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_marginTop="8dp">

                    <!-- Title row with fire emoji -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Fresh "
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#C850C0" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Memes "
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#8A6FDF" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Daily"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent_blue" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔥"
                        android:textSize="28sp"
                        android:layout_gravity="center"
                        android:layout_marginTop="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check out these viral hits!"
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"
                        android:layout_gravity="center" />

                    <!-- 2-column meme grid -->
                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/memes_grid_main"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:columnCount="2"
                        app:rowCount="3"
                        app:useDefaultMargins="true" />

                    <!-- Explore More Button -->
                    <Button
                        android:id="@+id/btn_see_more_memes"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Explore More Viral Memes →"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/gradient_button"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="20dp" />
                </LinearLayout>

                <!-- ── CTA Section ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1e2235"
                    android:padding="40dp"
                    android:gravity="center"
                    android:layout_marginTop="24dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ready to go " android:textSize="28sp" android:textStyle="bold"
                            android:textColor="#C850C0" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="viral?" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Join thousands of creators shaping internet culture with AI-generated memes."
                        android:textSize="15sp"
                        android:textColor="@color/text_secondary"
                        android:gravity="center"
                        android:layout_marginTop="16dp"
                        android:lineSpacingExtra="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚡" android:textSize="32sp" android:layout_marginEnd="12dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="🔥" android:textSize="32sp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ── Bottom Navigation Bar ── -->
        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:orientation="horizontal"
            android:background="@drawable/bottom_nav_bg"
            android:paddingHorizontal="16dp"
            android:gravity="center_vertical"
            android:weightSum="4">

            <!-- Home (active) -->
            <LinearLayout
                android:id="@+id/nav_home_btn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:background="@drawable/bottom_nav_active"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_home"
                    android:contentDescription="Home"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Generator -->
            <LinearLayout
                android:id="@+id/nav_generator_btn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_generator"
                    android:contentDescription="Generator" />
            </LinearLayout>

            <!-- Gallery -->
            <LinearLayout
                android:id="@+id/nav_gallery_btn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_gallery"
                    android:contentDescription="Gallery" />
            </LinearLayout>

            <!-- Login -->
            <LinearLayout
                android:id="@+id/nav_login_btn"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_logout"
                    android:contentDescription="Login" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ── Navigation Drawer (simplified) ── -->
    <LinearLayout
        android:id="@+id/nav_drawer_panel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#0f1221">

        <!-- Drawer Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="20dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_rocket"
                android:contentDescription="Logo" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="MEMEFY-AI"
                android:textColor="#C850C0"
                android:textSize="17sp"
                android:textStyle="italic|bold"
                android:layout_marginStart="10dp" />

            <ImageView
                android:id="@+id/btn_close_drawer"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_close"
                android:contentDescription="Close"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1e2235" android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NAVIGATE"
            android:textSize="11sp"
            android:textColor="#555970"
            android:letterSpacing="0.15"
            android:layout_marginStart="20dp"
            android:layout_marginBottom="8dp" />

        <!-- Home (active in drawer) -->
        <LinearLayout
            android:id="@+id/drawer_home"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bottom_nav_active"
            android:paddingHorizontal="20dp"
            android:layout_marginHorizontal="12dp"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_home" android:contentDescription="Home"
                android:layout_marginEnd="14dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Home" android:textColor="@color/accent_blue"
                android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>

        <!-- Generator -->
        <LinearLayout
            android:id="@+id/drawer_generator"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_generator" android:contentDescription="Generator"
                android:layout_marginEnd="14dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Generator" android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Gallery -->
        <LinearLayout
            android:id="@+id/drawer_gallery"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="32dp"
            android:layout_marginBottom="4dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_gallery" android:contentDescription="Gallery"
                android:layout_marginEnd="14dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gallery" android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#1e2235" android:layout_marginVertical="8dp"
            android:layout_marginHorizontal="20dp" />

        <!-- Light Mode toggle -->
        <LinearLayout
            android:id="@+id/drawer_light_mode"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="32dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_moon" android:contentDescription="Light Mode"
                android:layout_marginEnd="14dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Light Mode" android:textColor="@color/text_primary"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Spacer to push login to bottom -->
        <View android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Login button at bottom of drawer -->
        <Button
            android:id="@+id/drawer_login_btn"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="→  Login"
            android:textColor="#FFFFFF"
            android:background="@drawable/gradient_button"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_margin="16dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>