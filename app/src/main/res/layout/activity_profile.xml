<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primary_dark">

    <!-- Top Nav -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView android:layout_width="26dp" android:layout_height="26dp"
            android:src="@drawable/ic_rocket" android:contentDescription="Logo" />

        <TextView
            android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="MEMEFY-AI"
            android:textColor="@color/accent_blue"
            android:textSize="18sp" android:textStyle="bold"
            android:layout_marginStart="8dp" />

        <ImageView android:id="@+id/btn_menu"
            android:layout_width="30dp" android:layout_height="30dp"
            android:src="@drawable/ic_menu" android:contentDescription="Menu"
            android:clickable="true" android:focusable="true" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1e2235"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center">

                    <!-- Avatar with gradient ring -->
                    <FrameLayout
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        android:layout_marginBottom="4dp">

                        <View
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:background="@drawable/avatar_ring" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="104dp"
                            android:layout_height="104dp"
                            android:layout_gravity="center"
                            app:cardBackgroundColor="#0f1221"
                            app:cardCornerRadius="52dp"
                            app:cardElevation="0dp">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="👤"
                                android:textSize="48sp"
                                android:gravity="center" />
                        </androidx.cardview.widget.CardView>
                    </FrameLayout>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/tv_profile_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Meme Master"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="@color/accent_blue"
                        android:layout_marginTop="12dp" />

                    <!-- @handle -->
                    <TextView
                        android:id="@+id/tv_profile_handle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@memefyuser"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="20dp" />

                    <!-- Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Memes -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_memes_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="28sp" android:textStyle="bold"
                                android:textColor="@color/accent_blue" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="🎨 " android:textSize="12sp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="MEMES" android:textSize="11sp" android:textColor="@color/text_secondary"
                                    android:letterSpacing="0.1" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="1dp" android:layout_height="40dp"
                            android:background="#3a3f55" />

                        <!-- Views -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                            <TextView android:id="@+id/tv_views_count"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="0" android:textSize="28sp" android:textStyle="bold"
                                android:textColor="@color/accent_blue" />
                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="👁 " android:textSize="12sp" />
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="VIEWS" android:textSize="11sp" android:textColor="@color/text_secondary"
                                    android:letterSpacing="0.1" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Shares (below, centered) -->
                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:orientation="vertical" android:gravity="center" android:layout_marginTop="16dp">
                        <TextView android:id="@+id/tv_shares_count"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textSize="28sp" android:textStyle="bold"
                            android:textColor="@color/accent_blue" android:gravity="center" />
                        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:gravity="center" android:layout_marginTop="4dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📤 " android:textSize="12sp" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="SHARES" android:textSize="11sp" android:textColor="@color/text_secondary"
                                android:letterSpacing="0.1" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Edit Profile -->
                    <LinearLayout
                        android:id="@+id/btn_edit_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="24dp"
                        android:layout_marginTop="20dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="⚙ " android:textSize="14sp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Edit Profile" android:textSize="14sp"
                            android:textColor="@color/text_primary" />
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 🎨 Memes Count | ❤ Favorites toggle row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Memes tab (active) -->
                <LinearLayout
                    android:id="@+id/btn_tab_memes"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/gradient_button"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🎨 " android:textSize="18sp" />
                    <TextView android:id="@+id/tv_memes_tab_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/tag_blue_bg"
                        android:paddingHorizontal="8dp" android:paddingVertical="2dp" />
                </LinearLayout>

                <!-- Favorites tab -->
                <LinearLayout
                    android:id="@+id/btn_tab_favorites"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:background="@drawable/card_normal_border"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="❤ " android:textSize="18sp" />
                    <TextView android:id="@+id/tv_favorites_tab_count"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="16sp" android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:background="@drawable/card_normal_border"
                        android:paddingHorizontal="8dp" android:paddingVertical="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- MY MASTERPIECES title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_section_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="MY MASTERPIECES"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_blue" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/btn_refresh"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    app:cardBackgroundColor="#2d3142"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:clickable="true"
                    android:focusable="true">
                    <TextView android:layout_width="match_parent" android:layout_height="match_parent"
                        android:text="🔄" android:textSize="20sp" android:gravity="center" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_normal_border"
                android:padding="48dp"
                android:visibility="visible">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🎭" android:textSize="56sp" android:gravity="center" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Your gallery is empty...\ncringe! 🤡"
                    android:textSize="20sp" android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:gravity="center" android:layout_marginTop="16dp"
                    android:lineSpacingExtra="4dp" />

                <Button
                    android:id="@+id/btn_create_first_meme"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:text="Create First Meme ✨"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/gradient_button"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="28dp"
                    android:layout_marginTop="20dp" />
            </LinearLayout>

            <!-- Memes list container (populated programmatically) -->
            <LinearLayout
                android:id="@+id/memes_list_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav (logged in: 5 items, Profile active) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="@drawable/bottom_nav_bg"
        android:paddingHorizontal="4dp"
        android:gravity="center_vertical"
        android:weightSum="5">

        <LinearLayout android:id="@+id/nav_home_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_home" android:contentDescription="Home" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_create_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_generator" android:contentDescription="Create" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_gallery_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_gallery" android:contentDescription="Gallery" />
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_stats_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="vertical" android:gravity="center"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="22dp" android:layout_height="22dp"
                android:src="@drawable/ic_dashboard" android:contentDescription="Stats" />
        </LinearLayout>

        <!-- Profile active pill -->
        <LinearLayout android:id="@+id/nav_profile_btn"
            android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
            android:orientation="horizontal" android:gravity="center"
            android:background="@drawable/bottom_nav_active"
            android:paddingHorizontal="8dp"
            android:clickable="true" android:focusable="true">
            <ImageView android:layout_width="16dp" android:layout_height="16dp"
                android:src="@drawable/ic_profile" android:contentDescription="Profile"
                android:layout_marginEnd="4dp"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Profile" android:textColor="#FFFFFF" android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</LinearLayout>